# GIOP portal local development
VITE_SKIP_AUTH=true
VITE_SYNC_URL=/api/v1
# Optional trace seed MRID. Leave unset or omit the demo UUID — the portal auto-picks
# a connected node from the national graph when the demo island seed is detected.
# VITE_START_MRID=
# Default matches legacy backoffice-ui (direct Martin on :3001).
# Optional HTTP tile cache (./scripts/ensure_martin_cache.sh): http://127.0.0.1:3002
# Proxy form for production nginx: VITE_MARTIN_URL=/martin
# Zoom / minzoom settings are unchanged either way.
VITE_MARTIN_URL=http://127.0.0.1:3001
VITE_OCR_URL=/ocr-api/api/v1
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
# Live speech-to-speech copilot PoC (bottom-left "Live voice" button). Requires OpenAI key on sync-service.
VITE_GIOP_REALTIME=0
