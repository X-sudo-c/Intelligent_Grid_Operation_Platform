# Optional nginx front for Martin — cache tiles locally (production / heavy local).
# Prefer the checked-in config + helper:
#   ./scripts/ensure_martin_cache.sh
#   # serves http://127.0.0.1:3002 → Martin :3001
#   VITE_MARTIN_URL=http://127.0.0.1:3002
#
# Manual docker example (legacy):
#   docker run ... -v $PWD/config/nginx-martin-cache.conf:/etc/nginx/conf.d/default.conf:ro
#
# Does not change Martin or portal zoom settings.
# Converts Martin plain-text zoom 404s to empty 204 tiles (avoids MapLibre
# "Unimplemented type: 4") and does not browser-cache error bodies.

proxy_cache_path /var/cache/nginx/martin
                 levels=1:2
                 max_size=4g
                 inactive=2h
                 use_temp_path=off
                 keys_zone=martin_tiles:32m;

upstream giop_martin {
  server host.docker.internal:3001;
  keepalive 32;
}

map $upstream_status $martin_cache_control {
  default "no-store";
  ~^20[04]$ "public, max-age=3600";
}

server {
  listen 3001;
  server_name _;

  location / {
    proxy_http_version 1.1;
    proxy_set_header Connection "";
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Accept-Encoding gzip;

    proxy_cache martin_tiles;
    proxy_cache_lock on;
    proxy_cache_revalidate on;
    proxy_cache_valid 200 204 1h;
    proxy_cache_valid 404 0;
    proxy_cache_use_stale error timeout updating http_500 http_502 http_503 http_504;

    proxy_intercept_errors on;
    error_page 404 = @empty_tile;

    add_header X-Cache-Status $upstream_cache_status always;
    add_header Cache-Control $martin_cache_control always;

    proxy_pass http://giop_martin;
  }

  location @empty_tile {
    internal;
    default_type application/x-protobuf;
    add_header Cache-Control "no-store" always;
    add_header X-Cache-Status "BYPASS-404" always;
    return 204;
  }
}
