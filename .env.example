# GIOP Platform — Environment Variables
# Copy to .env and fill in values for local development.
#
# Supabase is run via npx (not a global install). Common commands:
#   npx supabase start          # start local stack (from project with supabase/)
#   npx supabase status         # show DB_URL, API_URL, keys
#   npx supabase db reset       # apply migrations in supabase/migrations/
#   npx supabase functions serve --env-file .env --no-verify-jwt
#
# Your running stack (supabase_db_x-x) is on port 54322 — shared across projects.
# Run `npx supabase status` from the directory where you started Supabase to get keys.

# Postgres password for Supabase local stack (default: postgres)
POSTGRES_PASSWORD=postgres

# Full psycopg2 connection string to Supabase Postgres (local default)
# Used by memgraph/bootstrap.py and sync-service webhook lookups
SUPABASE_DB_URI=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Max seconds for a background validation run before marking failed (default 7200 = 2h)
VALIDATION_RUN_TIMEOUT_SEC=7200

# Full connection string to TimescaleDB telemetry database (port 5433)
# Used by sync-service POST /api/v1/telemetry/submit
TIMESCALE_URI=postgresql://postgres:telemetry@127.0.0.1:5433/telemetry

# Sync-service webhook target (used by 00003_webhooks.sql triggers via host.docker.internal)
# Ensure sync-service is running on port 5000 before INSERT/UPDATE/DELETE on grid tables.

# Memgraph Bolt URI (sync-service also accepts GRAPH_DB_URI)
MEMGRAPH_URI=bolt://localhost:7687
GRAPH_DB_URI=bolt://localhost:7687

# Redis — optional shared cache for sync-service (graph chunks, trace, map nodes)
# Start with: ./scripts/ensure_redis.sh
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_CACHE_TTL_SEC=600
REDIS_GRAPH_CHUNK_CACHE_TTL_SEC=1800
REDIS_REFERENCE_LAYERS_CACHE_TTL_SEC=900
REDIS_OPS_CACHE_TTL_SEC=60
REDIS_SCHEMATIC_CACHE_TTL_SEC=900
REDIS_CIM_PREVIEW_TTL_SEC=300
REDIS_RULES_CACHE_TTL_SEC=3600
REDIS_LOCK_TTL_SEC=600
REDIS_WEBHOOK_DEDUP_TTL_SEC=86400
REDIS_IDEMPOTENCY_TTL_SEC=86400
REDIS_MAX_CONNECTIONS=32
REDIS_DELETE_BATCH_SIZE=500
REDIS_COMPRESS_MIN_BYTES=8192
REDIS_COMPRESS_LEVEL=6
REDIS_SINGLEFLIGHT_WAIT_SEC=45
REDIS_MAXMEMORY=2gb
REDIS_MAXMEMORY_POLICY=allkeys-lru

# Supabase Queues (pgmq) — durable background jobs in Postgres
PGMQ_CONSUMER_ENABLED=1
PGMQ_POLL_INTERVAL_SEC=2
PGMQ_VISIBILITY_TIMEOUT_SEC=7200
# Set to 1 to consume gis_import_jobs / gis_export_jobs (disable FastAPI BackgroundTasks for those routes first)
PGMQ_HANDLE_GIS_JOBS=0

# Topology analysis (NetworkX component stats when node count <= TOPOLOGY_GRAPH_MAX_NODES)
TOPOLOGY_GRAPH_MAX_NODES=75000
TOPOLOGY_GAPS_LIMIT=2000
TOPOLOGY_IMPACT_MAX_NODES=5000
# Geometric topology: max distance (m) between line endpoint and assigned node (ArcGIS dangle tolerance).
TOPO_ENDPOINT_TOLERANCE_M=1.0
# Master topology batch scan: default ETA (sec) and stale-run timeout (sec, no progress updates)
TOPOLOGY_SCAN_DEFAULT_ESTIMATE_SEC=420
TOPOLOGY_SCAN_STALE_SEC=900

# OCR service (PaddleOCR meter reading extraction) — port 5002
# Used by backoffice-ui meter upload panel; looks up serial → meter_mrid in Postgres
OCR_SERVICE_URL=http://localhost:5002

# Sync-service base URL — used by Flutter mobile app (field capture + telemetry)
# Android emulator: use http://10.0.2.2:5000
# Physical device: use http://<your-lan-ip>:5000
SYNC_SERVICE_URL=http://localhost:5000

# Trial backups (scripts/trial/*) — default .giop/backups/trial
# TRIAL_BACKUP_DIR=/var/backups/giop-trial
# TRIAL_CONFIRM=1

# Kafka / Avro telemetry pipeline (optional — run Kafka + Schema Registry separately)
KAFKA_BOOTSTRAP=localhost:9092
SCHEMA_REGISTRY_URL=http://localhost:8081
KAFKA_TOPIC=ghana-ami-telemetry-avro

# Supabase API keys — from `npx supabase status` (ANON_KEY, SERVICE_ROLE_KEY)
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_URL=http://127.0.0.1:54321

# Supabase Storage — GIS import/export buckets (migration 00031)
GIS_IMPORT_BUCKET=gis-imports
GIS_EXPORT_BUCKET=gis-exports
# Max upload bytes for sync-service import worker (default 2 GiB)
GIS_STORAGE_MAX_BYTES=2147483648

# SAP S/4HANA integration (mock-first — migration 00032)
# Mock mode returns fixtures/mock_customers.json when SAP_BASE_URL is empty.
SAP_MOCK_MODE=true
SAP_BASE_URL=
SAP_CLIENT_ID=
SAP_CLIENT_SECRET=
SAP_CUSTOMER_ODATA_PATH=/sap/opu/odata/sap/API_BUSINESS_PARTNER/A_BusinessPartner
SAP_CUSTOMER_SYNC_ENABLED=true

# Multi-agent validation LLM (optional — deterministic fallback when unset)
# OpenAI (default when using sk-proj… keys):
#   GIOP_LLM_BASE_URL=https://api.openai.com/v1
#   GIOP_LLM_MODEL=gpt-4o-mini
# Qwen / DashScope (OpenAI-compatible):
#   GIOP_LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
#   GIOP_LLM_MODEL=qwen-plus
# For sk-ws workspace keys, set GIOP_LLM_WORKSPACE_ID if you see Model.AccessDenied
GIOP_LLM_API_KEY=
GIOP_LLM_BASE_URL=https://api.openai.com/v1
GIOP_LLM_MODEL=gpt-4o-mini
GIOP_LLM_WORKSPACE_ID=
# Max tool-calling rounds per copilot turn (map/count/DQ/topology/KPI tools)
GIOP_LLM_MAX_TOOL_TURNS=8
# Sampling temperature (lower = more deterministic answers)
GIOP_LLM_TEMPERATURE=0.2
# Per-request timeout to the LLM provider (seconds)
GIOP_LLM_TIMEOUT_SEC=60

# Data cleaning / DQ agent cycle (Run agent cycle) — separate provider optional.
# Unset vars fall back to GIOP_LLM_* above.
# DeepSeek (OpenAI-compatible) — recommended for cleanup agent:
#   GIOP_CLEANUP_LLM_API_KEY=sk-...
#   GIOP_CLEANUP_LLM_BASE_URL=https://api.deepseek.com/v1
#   GIOP_CLEANUP_LLM_MODEL=deepseek-v4-flash
# Heavier reasoning for borderline tier B: deepseek-v4-pro
# Qwen example:
#   GIOP_CLEANUP_LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
#   GIOP_CLEANUP_LLM_MODEL=qwen-plus
GIOP_CLEANUP_LLM_API_KEY=
GIOP_CLEANUP_LLM_BASE_URL=https://api.deepseek.com/v1
GIOP_CLEANUP_LLM_MODEL=deepseek-v4-flash
GIOP_CLEANUP_LLM_DEEP_MODEL=deepseek-v4-pro
# Endpoint fix AI scan — max rows per LLM call (1–100) and district batch size
GIOP_ENDPOINT_AI_SCAN_MAX_LIMIT=100
GIOP_ENDPOINT_AI_SCAN_DEFAULT_LIMIT=10
GIOP_ENDPOINT_AI_SCAN_MAX_OUTPUT_TOKENS=8192
GIOP_ENDPOINT_AI_DISTRICT_BATCH_SIZE=25
GIOP_AI_SWARM_MAX_INFLIGHT=32
GIOP_ENDPOINT_AI_CLAIM_TTL_SEC=600
REDIS_ENDPOINT_FIX_RUN_TTL_SEC=7200
REDIS_ENDPOINT_FIX_RUN_TTL_SEC=7200
GIOP_CLEANUP_LLM_WORKSPACE_ID=
GIOP_CLEANUP_LLM_MAX_TOOL_TURNS=8
GIOP_CLEANUP_LLM_TEMPERATURE=0.1
GIOP_CLEANUP_LLM_TIMEOUT_SEC=120

# Live speech-to-speech PoC (OpenAI Realtime, WebRTC). Only works with an OpenAI key/base.
GIOP_REALTIME_MODEL=gpt-realtime
DQ_STALE_ASSET_DAYS=365

# Voice copilot — Supertonic local TTS (./scripts/start-supertonic.sh)
SUPERTONIC_URL=http://127.0.0.1:7788
SUPERTONIC_VOICE=F1
SUPERTONIC_LANG=en
# Voice copilot — STT + TTS
# OpenAI STT only (fast; uses GIOP_LLM_API_KEY). Audio goes straight to copilot in one API hop.
VOICE_STT_PROVIDER=openai
VOICE_STT_MODEL=gpt-4o-mini-transcribe
# Fallback if mini-transcribe unavailable: whisper-1
# VOICE_STT_MODEL=whisper-1
VOICE_STT_LANGUAGE=en
VOICE_STT_TIMEOUT_SEC=30
# Optional separate key/base — defaults to GIOP_LLM_API_KEY / GIOP_LLM_BASE_URL
# VOICE_STT_API_KEY=
# VOICE_STT_BASE_URL=https://api.openai.com/v1
# Local Whisper (offline — VOICE_STT_PROVIDER=local):
# pip install -r sync-service/requirements-voice.txt
# VOICE_STT_MODEL=small
# VOICE_STT_DEVICE=cpu
# VOICE_STT_COMPUTE_TYPE=int8
# VOICE_STT_BEAM_SIZE=8
# VOICE_STT_PATIENCE=1.2
# Optional domain prompt for Whisper / OpenAI STT:
# VOICE_STT_INITIAL_PROMPT=Ghana ECG GIS: Accra, Kumasi, Tamale, Tema, Pokuase, feeder, district, poles
VOICE_COUNT_CACHE_TTL_SEC=900
VOICE_SESSION_TTL_SEC=3600
# Resolve towns via OSM when not in ECG district list (set 0 to disable)
PLACE_GEOCODE_ENABLED=1
# Redis TTL for repeat place lookups (voice/map navigation latency)
PLACE_GEOCODE_CACHE_TTL_SEC=86400
PLACE_RESOLVE_CACHE_TTL_SEC=3600
